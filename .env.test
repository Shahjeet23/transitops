# Server
PORT=5000
NODE_ENV=test

# MongoDB (Test Database)
MONGODB_URI=mongodb://localhost:27017/transitops_test

# Client Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000/api
CLIENT_URL=http://localhost:3000

# JWT Secrets (Use secure strings in production)
JWT_SECRET=super_secret_test_key_for_jwt
JWT_REFRESH_SECRET=super_secret_refresh_key_for_jwt
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Third Party APIs
GEMINI_API_KEY=your_gemini_api_key_here

# Master Admin Credentials (For Seeding)
ADMIN_EMAIL=admin@transitops.com
ADMIN_PASSWORD=AdminPassword123!
ADMIN_NAME=System Admin